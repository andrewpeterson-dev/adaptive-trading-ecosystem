# Adaptive Trading Ecosystem — Environment Variables
# Copy to .env and fill in values
#
# VERCEL DEPLOYMENT: vars marked [VERCEL-REQUIRED] MUST be set in Vercel
# dashboard or the deploy will fail / return 5xx on those routes.

# ═══════════════════════════════════════════════════════════
# REQUIRED (app won't function without these)
# ═══════════════════════════════════════════════════════════

JWT_SECRET=           # [VERCEL-REQUIRED] Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=       # [VERCEL-REQUIRED] Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Database ---
# For Vercel/Railway: set DATABASE_URL to your managed PostgreSQL connection string
DATABASE_URL=         # [VERCEL-REQUIRED] e.g. postgresql://user:pass@host:5432/dbname (Railway/Neon/Supabase)
USE_SQLITE=true       # Set false for production (SQLite won't work on Vercel serverless)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_ecosystem
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme

# --- Backend API URL (frontend → backend proxy) ---
API_URL=              # [VERCEL-REQUIRED] Backend URL, e.g. https://your-api.railway.app
                      # Falls back to Railway URL in prod if not set

# --- Frontend URLs ---
NEXT_PUBLIC_API_URL=  # [VERCEL-REQUIRED] Public backend URL for client-side calls
NEXT_PUBLIC_WS_URL=   # [VERCEL-REQUIRED] WebSocket URL, e.g. wss://your-api.railway.app/ws
BASE_URL=http://localhost:3000  # Frontend URL for email verification links

# ═══════════════════════════════════════════════════════════
# REDIS (required for WebSocket, rate limiting, caching)
# ═══════════════════════════════════════════════════════════

REDIS_URL=            # [VERCEL-REQUIRED if using WS/rate-limiting] e.g. redis://default:pass@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════
# BROKER
# ═══════════════════════════════════════════════════════════

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Separate paper/live keys (optional)
PAPER_API_KEY=
PAPER_SECRET_KEY=
LIVE_API_KEY=
LIVE_SECRET_KEY=
# Webull credentials are per-user, stored encrypted in DB

# ═══════════════════════════════════════════════════════════
# LLM / AI
# ═══════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=    # [VERCEL-REQUIRED for Cerberus AI]
OPENAI_API_KEY=       # [VERCEL-REQUIRED for Cerberus AI]
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# --- Cerberus model routing ---
OPENAI_PRIMARY_MODEL=gpt-5.4
OPENAI_LOW_LATENCY_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EXPERT_MODEL=gpt-5.4-pro
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6
PERPLEXITY_API_KEY=
PERPLEXITY_SEARCH_MODEL=sonar
PERPLEXITY_DEEP_RESEARCH_MODEL=sonar-deep-research
BROKER_KMS_KEY_ID=

# --- FinGPT Sentiment Analysis ---
FINGPT_ENDPOINT=      # HuggingFace Inference API endpoint (leave empty for default FinGPT model)
FINGPT_API_KEY=       # HuggingFace API token (get from https://huggingface.co/settings/tokens)
FINGPT_ENABLED=false  # Set true to use FinGPT; false falls back to GPT-based sentiment
SENTIMENT_CACHE_TTL=900  # Cache TTL in seconds (default: 900 = 15 min)

# --- Ollama (local LLM, dev only) ---
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ═══════════════════════════════════════════════════════════
# MARKET DATA (optional — yFinance is free fallback)
# ═══════════════════════════════════════════════════════════

FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# ═══════════════════════════════════════════════════════════
# EMAIL (required for email verification / password reset)
# ═══════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=        # Gmail app password

# ═══════════════════════════════════════════════════════════
# S3 STORAGE (required for document ingestion)
# ═══════════════════════════════════════════════════════════

S3_BUCKET=trading-cerberus
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=http://localhost:9000  # MinIO for dev; remove for AWS

# ═══════════════════════════════════════════════════════════
# CORS / SECURITY
# ═══════════════════════════════════════════════════════════

CORS_ORIGINS=http://localhost:3000  # Comma-separated; add Vercel URL for prod

# ═══════════════════════════════════════════════════════════
# WORKERS (Celery)
# ═══════════════════════════════════════════════════════════

CELERY_BROKER_URL=    # Defaults to REDIS_URL if empty

# ═══════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════

WEBHOOK_URL=          # Slack/Discord webhook for failure alerts
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════

FEATURE_CERBERUS_ENABLED=true
FEATURE_RESEARCH_MODE_ENABLED=true
FEATURE_BOT_MUTATIONS_ENABLED=false
FEATURE_PAPER_TRADE_PROPOSALS_ENABLED=false
FEATURE_LIVE_TRADE_PROPOSALS_ENABLED=false
FEATURE_SLOW_EXPERT_MODE_ENABLED=false
FEATURE_EXPERIMENTAL_RL_ENABLED=false

# ═══════════════════════════════════════════════════════════
# TRADING CONFIG (usually fine as defaults)
# ═══════════════════════════════════════════════════════════

TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
MAX_POSITION_SIZE_PCT=0.10
MAX_PORTFOLIO_EXPOSURE_PCT=0.80
MAX_DRAWDOWN_PCT=0.15
STOP_LOSS_PCT=0.03
INITIAL_CAPITAL=100000

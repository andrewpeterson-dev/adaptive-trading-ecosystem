# =============================================================================
# Adaptive Trading Ecosystem — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.
# =============================================================================

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_ecosystem
POSTGRES_USER=trader
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- LLM Intelligence ---
# At least one API key required for the AI Intelligence tab
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_ANALYSIS_INTERVAL_MINUTES=15
LLM_TEMPERATURE=0.3

# --- Alpaca API (backward-compatible defaults) ---
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Alpaca Paper/Live Key Separation ---
# If set, these override ALPACA_API_KEY/SECRET for the respective mode
PAPER_API_KEY=
PAPER_SECRET_KEY=
LIVE_API_KEY=
LIVE_SECRET_KEY=

# --- Trading Mode ---
# Options: backtest, paper, live
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false

# --- Risk Parameters ---
MAX_POSITION_SIZE_PCT=0.10
MAX_PORTFOLIO_EXPOSURE_PCT=0.80
MAX_DRAWDOWN_PCT=0.15
STOP_LOSS_PCT=0.03
MAX_TRADES_PER_HOUR=20

# --- Model Retraining ---
RETRAIN_INTERVAL_HOURS=24
WALK_FORWARD_WINDOW_DAYS=252
PERFORMANCE_DECAY_THRESHOLD=0.3

# --- Capital Allocation ---
INITIAL_CAPITAL=100000.0
MIN_MODEL_WEIGHT=0.05
MAX_MODEL_WEIGHT=0.40

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
AUDIT_LOG_PATH=logs/trade-log.jsonl

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard ---
DASHBOARD_PORT=8501

# --- Auth & Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_A_FERNET_KEY
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
BASE_URL=http://localhost:8501
